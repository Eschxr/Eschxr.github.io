---
import CrackTrigger from "../components/CrackTrigger.astro";
import PlainPortfolio from "../components/PlainPortfolio.astro";
import RetroPortfolio from "../components/RetroPortfolio.astro";
import "../styles/global.css";
import "../styles/plain.css";
import "../styles/retro.css";

const faviconPath = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A personal portfolio with a hidden retro reveal." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    <title>Personal Website</title>
  </head>
  <body>
    <PlainPortfolio />
    <CrackTrigger />
    <button id="orb-fallback-button" class="orb-fallback-button" type="button" hidden>
      Reveal the hidden retro site
    </button>
    <p id="experience-status" class="sr-only" aria-live="polite"></p>
    <RetroPortfolio />

    <script>
      import "../scripts/experience";
    </script>
  </body>
</html>
